generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ? ENUMS
enum Role {
  SUPER_ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum UserStatus {
  PENDING_ACTIVATION
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum OrgRole {
  OWNER
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

// ? USER & AUTH

model User {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  mobile           String     @unique
  isMobileVerified Boolean    @default(false)
  email            String     @unique
  isEmailVerified  Boolean    @default(false)
  password         String
  role             Role       @default(EMPLOYEE)
  status           UserStatus @default(PENDING_ACTIVATION)

  refreshTokens           RefreshToken[]
  activityLogs            ActivityLog[]
  organizationInvitations Invitation[]
  organizationMembers     OrganizationMember[]
  ownedOrganizations      Organization[]       @relation("OrganizationOwner")
  notifications           Notification[]
  UserPermission          UserPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Permission {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique

  rolePermissions RolePermission[]
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("permission")
}

model RolePermission {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  role         OrgRole
  permissionId String  @db.ObjectId

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([role, permissionId])
  @@map("role_permission")
}

model UserPermission {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  userId       String @db.ObjectId
  permissionId String @db.ObjectId

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  User       User       @relation(fields: [userId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("user_permission")
}

model RefreshToken {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  token  String @unique
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ip         String?
  userAgent  String?
  device     String?
  expiresAt  DateTime
  isRevoked  Boolean   @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@map("refresh_tokens")
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  ip        String?
  device    String?
  browser   String?
  os        String?
  userAgent String?
  latitude  Float?
  longitude Float?
  country   String?
  city      String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("activity_logs")
}

// ? Notification

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// ? ORGANIZATION CORE

model Organization {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  slug    String @unique
  ownerId String @db.ObjectId
  owner   User   @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  logo         String?
  domain       String?
  primaryColor String?

  members      OrganizationMember[]
  invitations  Invitation[]
  branches     Branch[]
  settings     OrganizationSettings?
  subscription Subscription?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Department Department[]

  @@map("organizations")
}

model OrganizationMember {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  userId         String @db.ObjectId
  organizationId String @db.ObjectId

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  role OrgRole @default(EMPLOYEE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_members")
}

model Invitation {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  email          String
  userId         String?          @db.ObjectId
  organizationId String           @db.ObjectId
  role           OrgRole
  token          String           @unique
  expiresAt      DateTime
  status         InvitationStatus @default(PENDING)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, userId])
  @@map("invitations")
}

model Branch {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  location String?

  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("branches")
}

model OrganizationSettings {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String @unique @db.ObjectId

  timezone String @default("UTC")
  currency String @default("USD")
  language String @default("en")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_settings")
}

model Subscription {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String @unique @db.ObjectId

  plan      Plan      @default(FREE)
  maxUsers  Int       @default(5)
  expiresAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Department {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?

  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("departments")
}
